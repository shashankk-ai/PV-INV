# =============================================
# LITMUS — Environment Configuration
# =============================================
# Copy this file to .env and fill in values.
# Never commit .env to source control.

# --- Database ---
DATABASE_URL="postgresql://litmus:litmus_dev_pass@localhost:5432/litmus_db"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- JWT Secrets (generate with: openssl rand -base64 64) ---
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# --- Server ---
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# --- Photo Storage ---
# Set STORAGE_BACKEND to "s3" or "local" (default: local for dev)
STORAGE_BACKEND=local
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""

# --- Zoho Analytics ---
# Leave blank to use mock data (30 chemical items)
ZOHO_API_KEY=""
ZOHO_VIEW_ID=""
ZOHO_ORG_ID=""
SYNC_INTERVAL_MINUTES=30

# --- Feature Flags ---
OCR_ENABLED=false

# --- Rate Limiting ---
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=60000
